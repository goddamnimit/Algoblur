rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: ads
    // Fields: title, description, category, imageUrl, targetUrl, price, createdAt
    //
    // Collection: interactions
    // Fields: userId, adId, type, category, timestamp
    //
    // Collection: users
    // Fields: userId, noiseLevel, interactionsCount, categoriesObfuscated
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "nimitdesa@gmail.com" && request.auth.token.email_verified == true));
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') && time <= request.time;
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidAd(data) {
      let allowed = ['title', 'description', 'category', 'imageUrl', 'targetUrl', 'price', 'createdAt'];
      return hasOnlyAllowedFields(data, allowed) &&
             data.keys().hasAll(['title', 'description', 'category', 'imageUrl', 'targetUrl', 'price', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() < 500 &&
             data.category is string && data.category.size() < 50 &&
             isValidUrl(data.imageUrl) && data.imageUrl.size() < 500 &&
             isValidUrl(data.targetUrl) && data.targetUrl.size() < 500 &&
             data.price is number && data.price >= 0 &&
             data.createdAt is timestamp && isRecent(data.createdAt);
    }

    function isValidInteraction(data) {
      let allowed = ['userId', 'adId', 'type', 'category', 'timestamp'];
      return hasOnlyAllowedFields(data, allowed) &&
             data.keys().hasAll(['userId', 'adId', 'type', 'category', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.adId is string && data.adId.size() < 100 &&
             data.type in ['view', 'skip', 'click'] &&
             data.category is string && data.category.size() < 50 &&
             data.timestamp is timestamp && isRecent(data.timestamp);
    }

    function isValidUserProfile(data) {
      let allowed = ['userId', 'noiseLevel', 'interactionsCount', 'categoriesObfuscated', 'ghostModeActive', 'activeModeActive', 'activePersona', 'role'];
      return hasOnlyAllowedFields(data, allowed) &&
             data.keys().hasAll(['userId', 'noiseLevel', 'interactionsCount', 'role']) &&
             data.userId == request.auth.uid &&
             data.noiseLevel is number && data.noiseLevel >= 0 && data.noiseLevel <= 100 &&
             data.interactionsCount is number && data.interactionsCount >= 0 &&
             data.categoriesObfuscated is list && data.categoriesObfuscated.size() < 100 &&
             data.role in ['admin', 'user'];
    }

    function isValidCampaign(data) {
      let allowed = ['businessId', 'businessName', 'adId', 'budget', 'impressionsRemaining', 'status'];
      return hasOnlyAllowedFields(data, allowed) &&
             data.keys().hasAll(['businessId', 'businessName', 'adId', 'budget', 'impressionsRemaining', 'status']) &&
             data.businessId == request.auth.uid &&
             data.businessName is string && data.businessName.size() > 0 && data.businessName.size() < 100 &&
             data.adId is string && data.adId.size() < 100 &&
             data.budget is number && data.budget >= 0 &&
             data.impressionsRemaining is number && data.impressionsRemaining >= 0 &&
             data.status in ['active', 'paused', 'completed'];
    }

    function isValidGhostJourney(data) {
      let allowed = ['userId', 'targetUrl', 'persona', 'timestamp'];
      return hasOnlyAllowedFields(data, allowed) &&
             data.keys().hasAll(['userId', 'targetUrl', 'persona', 'timestamp']) &&
             data.userId == request.auth.uid &&
             isValidUrl(data.targetUrl) && data.targetUrl.size() < 500 &&
             data.persona is string && data.persona.size() < 100 &&
             data.timestamp is timestamp && isRecent(data.timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /ads/{adId} {
      allow read: if true; // Ads are public
      allow create: if isAdmin() && isValidAd(request.resource.data);
      allow update: if isAdmin() && isValidAd(request.resource.data) && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAdmin();
    }

    match /interactions/{interactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidInteraction(request.resource.data);
      allow update, delete: if false; // Interactions are immutable
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) && 
                      areImmutableFieldsUnchanged(['userId', 'role']) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data);
      allow update: if isAuthenticated() && 
                      (resource.data.businessId == request.auth.uid || isAdmin()) &&
                      isValidCampaign(request.resource.data) &&
                      areImmutableFieldsUnchanged(['businessId', 'adId']) &&
                      request.resource.data.businessId == resource.data.businessId;
      allow delete: if isAdmin();
    }

    match /ghost_journeys/{journeyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidGhostJourney(request.resource.data);
      allow update, delete: if false;
    }
  }
}
